# ============================================================
# DataFlow E-Commerce Platform — Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# ============================================================

# GCP
GCP_PROJECT=dataflow-prod
GCP_REGION=europe-west1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCS_BRONZE_BUCKET=dataflow-bronze
GCS_SILVER_BUCKET=dataflow-silver
GCS_GOLD_BUCKET=dataflow-gold

# Snowflake
SNOWFLAKE_ACCOUNT=your-account.eu-west-1
SNOWFLAKE_USER=data_engineer
SNOWFLAKE_PASSWORD=your-password
SNOWFLAKE_DATABASE=DATAFLOW_PROD
SNOWFLAKE_WAREHOUSE=COMPUTE_WH_ANALYTICS
SNOWFLAKE_ROLE=DATA_ENGINEER_ROLE
SNOWFLAKE_SCHEMA=PUBLIC

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/ecommerce
MONGODB_DATABASE=ecommerce
jyQcYVrefc4nHcF6
azureazureazure1234_db_user
# Redis
REDIS_URL=redis://redis-cluster:6379/0
REDIS_MAX_CONNECTIONS=50

# Kafka
KAFKA_BROKERS=kafka-broker-1:9092,kafka-broker-2:9092,kafka-broker-3:9092
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=your-kafka-user
KAFKA_SASL_PASSWORD=your-kafka-password

# Airbyte
AIRBYTE_API_URL=http://airbyte-server:8001
AIRBYTE_API_KEY=your-airbyte-api-key

# Datadog
DD_AGENT_HOST=localhost
DD_STATSD_PORT=8125
DD_API_KEY=your-datadog-api-key

# Airflow
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/1
AIRFLOW__WEBSERVER__SECRET_KEY=change-me-in-production

# Slack
SLACK_WEBHOOK_DATA_ALERTS=https://hooks.slack.com/services/your/webhook/url
